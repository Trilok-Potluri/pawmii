{
  "cli": {
    "version": ">= 12.0.0",
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "ios": {
        "autoIncrement": true
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "PLACEHOLDER_SET_IN_CONFIG_JSON",
        "ascAppId": "PLACEHOLDER_SET_IN_CONFIG_JSON"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}
