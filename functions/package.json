{
  "name": "@pawmii/functions",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=lib/index.js --external:firebase-admin --external:firebase-functions",
    "build:watch": "npm run build -- --watch",
    "deploy": "npm run build && firebase deploy --only functions",
    "deploy:prod": "npm run build && firebase deploy --only functions --project pawmii-app",
    "emulate": "npm run build && firebase emulators:start --only functions,firestore",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  }
}
